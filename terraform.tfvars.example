# Copy this file to terraform.tfvars and fill in your values
# terraform.tfvars is git-ignored to protect secrets

tenancy_ocid     = "ocid1.tenancy.oc1..xxxxx"
user_ocid        = "ocid1.user.oc1..xxxxx"
fingerprint      = "xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx"
private_key_path = "~/.oci/oci_api_key.pem"
region           = "us-ashburn-1"
compartment_id   = "ocid1.compartment.oc1..xxxxx"

# VCN
vcn_name      = "oke-vcn"
vcn_cidr      = "10.0.0.0/16"
vcn_dns_label = "okevcn"

# Subnets
public_subnet_cidr       = "10.0.0.0/24"
private_subnet_cidr      = "10.0.1.0/24"
public_subnet_dns_label  = "pub"
private_subnet_dns_label = "priv"

# OKE
cluster_name       = "oke-cluster"
kubernetes_version = "v1.29.1"

# Node Pool
node_pool_name  = "oke-node-pool"
node_shape      = "VM.Standard.E4.Flex"
node_ocpus      = 2
node_memory_gbs = 16
node_image_id   = "ocid1.image.oc1.iad.xxxxx"   # OKE worker node image
node_count      = 3
ssh_public_key  = "ssh-rsa AAAA..."

# Tags
tags = {
  environment = "dev"
  team        = "platform"
}
